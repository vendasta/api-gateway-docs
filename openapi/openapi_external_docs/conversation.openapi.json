  "info": {
    "title": "Conversation OpenAPI Documentation",
    "version": "1.0.0"
  },
  "openapi": "3.0.0",
  "paths": {
    "/conversation/v1/conversations": {
      "get": {
        "operationId": "ConversationService_ListConversations",
        "parameters": [
          {
            "description": "The account group ID to scope conversations to (e.g. \"AG-XXXXXX\")",
            "in": "query",
            "name": "accountGroupId",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "The participant ID of the viewing user (e.g. \"PARTICIPANT-XXX\"). Used for unread status.",
            "in": "query",
            "name": "participantId",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "cursor can be passed to retrieve the next page of results keyed by the cursor",
            "in": "query",
            "name": "pagingOptions.cursor",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "page_size specifies the number of items to return in the next page",
            "in": "query",
            "name": "pagingOptions.pageSize",
            "schema": {
              "format": "int32",
              "type": "integer"
            }
          },
          {
            "description": "channels filters to conversations on any of the specified channels. Empty = all channels.\n\n - CONVERSATION_CHANNEL_GOOGLE_BUSINESS_COMMUNICATIONS: Deprecated: Google Business Messaging is no longer supported\n - CONVERSATION_CHANNEL_PERSONAL_EMAIL: Personal email via Gmail/Outlook platform integration.\nMessage content is stored in Email service (TrackedMessageContent), retrieved via tracked_message_id metadata.\n - CONVERSATION_CHANNEL_SYSTEM: Conversation channel for events which have no associated provider.",
            "explode": true,
            "in": "query",
            "name": "filters.channels",
            "schema": {
              "items": {
                "enum": [
                  "CONVERSATION_CHANNEL_UNDEFINED",
                  "CONVERSATION_CHANNEL_INTERNAL",
                  "CONVERSATION_CHANNEL_SMS",
                  "CONVERSATION_CHANNEL_FACEBOOK",
                  "CONVERSATION_CHANNEL_GOOGLE_MESSAGES",
                  "CONVERSATION_CHANNEL_OPENAI",
                  "CONVERSATION_CHANNEL_EMAIL",
                  "CONVERSATION_CHANNEL_GOOGLE_BUSINESS_COMMUNICATIONS",
                  "CONVERSATION_CHANNEL_WEB_CHAT",
                  "CONVERSATION_CHANNEL_INSTAGRAM",
                  "CONVERSATION_CHANNEL_WHATSAPP",
                  "CONVERSATION_CHANNEL_AI_ASSISTANT",
                  "CONVERSATION_CHANNEL_GOOGLE_CHAT",
                  "CONVERSATION_CHANNEL_PERSONAL_EMAIL",
                  "CONVERSATION_CHANNEL_SYSTEM"
                ],
                "type": "string"
              },
              "type": "array"
            }
          },
          {
            "description": "is_open filters by conversation open/closed state. Unset = all conversations.",
            "in": "query",
            "name": "filters.isOpen",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "description": "unread_only, when true, returns only conversations where participant_id has not seen the latest activity.",
            "in": "query",
            "name": "filters.unreadOnly",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "description": "awaiting_response_only, when true, returns only conversations where the most recent message was from a\nnon-owner participant (e.g. a customer). Note: backed by a field only populated from 2024-09 onward;\nolder conversations without data will be excluded.",
            "in": "query",
            "name": "filters.awaitingResponseOnly",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/v1ListConversationsResponse"
                }
              }
            },
            "description": "A successful response."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/googlerpcStatus"
                }
              }
            },
            "description": "An unexpected error response."
          }
        },
        "security": [
          {
            "OAuth2": [
              "business-app"
            ]
          }
        ],
        "summary": "List conversations for inbox filtering, backed by CloudSQL",
        "tags": [
          "ConversationService"
        ]
      }
    },
    "/v1/conversation/communication-channels-info": {
      "post": {
        "operationId": "ConversationService_ListCommunicationChannelsInfo",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/v1ListCommunicationChannelsInfoRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/v1ListCommunicationChannelsInfoResponse"
                }
              }
            },
            "description": "A successful response."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/googlerpcStatus"
                }
              }
            },
            "description": "An unexpected error response."
          }
        },
        "security": [
          {
            "OAuth2": [
              "conversation:read",
              "conversation",
              "business-app"
            ]
          }
        ],
        "summary": "List communication channels info for a business",
        "tags": [
          "ConversationService"
        ]
      }
    },
    "/v1beta/widgets": {
      "get": {
        "operationId": "ConversationService_ListWidgets",
        "parameters": [
          {
            "description": "The namespace of the widget e.g. \"ABC\", \"AG-123\"\nUse either namespace or options.namespaces",
            "in": "query",
            "name": "namespace",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "cursor can be passed to retrieve the next page of results keyed by the cursor",
            "in": "query",
            "name": "pagingOptions.cursor",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "page_size specifies the number of items to return in the next page",
            "in": "query",
            "name": "pagingOptions.pageSize",
            "schema": {
              "format": "int32",
              "type": "integer"
            }
          },
          {
            "description": "The namespaces of the widgets e.g. \"ABC\", \"AG-123\"\nUse either namespace or options.namespaces",
            "explode": true,
            "in": "query",
            "name": "options.namespaces",
            "schema": {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          },
          {
            "description": "The types of the widget e.g. \"inbox-pro\", \"my-listings\"",
            "explode": true,
            "in": "query",
            "name": "options.widgetTypes",
            "schema": {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/v1ListWidgetsResponse"
                }
              }
            },
            "description": "A successful response."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/googlerpcStatus"
                }
              }
            },
            "description": "An unexpected error response."
          }
        },
        "security": [
          {
            "OAuth2": [
              "business-app",
              "conversation.widget"
            ]
          }
        ],
        "summary": "List widgets",
        "tags": [
          "ConversationService"
        ]
      }
    }
  },
  "servers": [
    {
      "description": "Production",
      "url": "https://prod.apigateway.co/grpc"
    }
  ],
  "tags": [
    {
      "name": "ConversationService"
    }
  ]
}