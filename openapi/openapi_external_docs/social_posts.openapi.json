      "v1TikTokCustomization": {
        "description": "TikTokCustomization contains TikTok-specific options for video posts.\nAI agents should default to enabling community features (comments, duets, stitches)\nunless the user requests otherwise or the content is sensitive/private.",
        "properties": {
          "allowComment": {
            "description": "Whether viewers can comment on the video. Default: true for public engagement.",
            "type": "boolean"
          },
          "allowDuet": {
            "description": "Whether other users can create duet videos (side-by-side reactions).\nDisable for branded content that shouldn't be remixed. Default: true.",
            "type": "boolean"
          },
          "allowStitch": {
            "description": "Whether other users can stitch/use clips from this video in their content.\nDisable for copyrighted or sensitive material. Default: true.",
            "type": "boolean"
          },
          "isBrandOrganic": {
            "description": "REQUIRED by TikTok: Whether this is organic brand content (not paid promotion).\nSet to true for regular business posts, false for paid advertising.",
            "type": "boolean"
          },
          "isBrandedContent": {
            "description": "REQUIRED by TikTok: Whether this video contains branded content or product placement.\nSet to true if showcasing products/services, false for general content.",
            "type": "boolean"
          }
        },
        "type": "object"
      },
