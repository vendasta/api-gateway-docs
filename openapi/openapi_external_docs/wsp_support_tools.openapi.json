    "/v1/wph/support-tools/chat": {
      "post": {
        "operationId": "SiteManager_ChatCompletion",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/v1ChatCompletionRequest"
              }
            }
          },
          "description": "Request to generate a chat completion response.",
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/v1ChatCompletionResponse"
                }
              }
            },
            "description": "A successful response."
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/rpcStatus"
                }
              }
            },
            "description": "An unexpected error response."
          }
        },
        "security": [
          {
            "OAuth2": [
              "user:read"
            ]
          }
        ],
        "summary": "Chat Completion",
        "tags": [
          "SiteManager"
        ]
      }
    },
